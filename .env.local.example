# Copy to .env.local and fill in real values. Never commit .env.local (already gitignored).
# See CLAUDE.md §6 for what each key is for and where to obtain it.

# Magic (magic.link) — social login / embedded wallet signer
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=

# ZeroDev — smart account + bundler/paymaster + Smart Routing Address
ZERODEV_PROJECT_ID=
ZERODEV_RPC=
# Same values as above, but NEXT_PUBLIC_-prefixed so they're readable client-side — Kernel
# account creation AND Smart Routing Address creation both happen in the browser.
NEXT_PUBLIC_ZERODEV_RPC=
NEXT_PUBLIC_ZERODEV_PROJECT_ID=

# Chain selection
NEXT_PUBLIC_CHAIN=arbitrum            # arbitrum | arbitrumSepolia

# Settlement asset — verify on Arbiscan/Circle before use (see CLAUDE.md §0)
NEXT_PUBLIC_USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831

# Checkout.sol deployment address — see context/deployments.md for current addresses per network.
# SRA's destChain is always Arbitrum One (mainnet) — this MUST be a mainnet deployment address
# for the SRA-triggered fulfillOrder call to actually hit a real contract. Not yet deployed there.
NEXT_PUBLIC_CHECKOUT_CONTRACT_ADDRESS_MAINNET=

# Supabase — off-chain product/order metadata + status cache
SUPABASE_URL=
SUPABASE_ANON_KEY=
